# AI Fluency Platform — Environment Variables
# Copy this file to .env and fill in the required values.
#
#   cp .env.example .env
#
# NEVER commit .env to git. It is gitignored.
# Generate secrets with: openssl rand -base64 64

# ─────────────────────────────────────
# PostgreSQL (docker-compose local dev)
# ─────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_change_in_production
POSTGRES_DB=ai_fluency_dev

# ─────────────────────────────────────
# Database
# ─────────────────────────────────────
# Local dev (plain):
DATABASE_URL=postgresql://postgres:postgres_change_in_production@localhost:5432/ai_fluency_dev

# Admin URL (used for migrations — same as DATABASE_URL in local dev):
DATABASE_ADMIN_URL=postgresql://postgres:postgres_change_in_production@localhost:5432/ai_fluency_dev

# ─────────────────────────────────────
# Redis
# ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────
# JWT Secrets (REQUIRED — no defaults)
# Generate: openssl rand -base64 64
# ─────────────────────────────────────
JWT_SECRET=generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=generate_with_different_openssl_rand_base64_64

# ─────────────────────────────────────
# API
# ─────────────────────────────────────
PORT=5014
NODE_ENV=development

# ─────────────────────────────────────
# Web / Frontend
# ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5014

# ─────────────────────────────────────
# Optional: Observability
# ─────────────────────────────────────
# SENTRY_DSN=
# LOG_LEVEL=debug
