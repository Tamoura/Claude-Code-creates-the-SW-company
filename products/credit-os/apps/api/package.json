{
  "name": "@credit-os/api",
  "version": "0.1.0",
  "private": true,
  "description": "Composable Credit OS API — Fastify modular monolith (:5016)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "depcruise": "depcruise src",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@connectsw/audit": "workspace:*",
    "@connectsw/auth": "workspace:*",
    "@connectsw/observability": "workspace:*",
    "@connectsw/shared": "workspace:*",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@prisma/client": "^5.22.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "json-rules-engine": "^7.3.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@connectsw/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.17.0",
    "eslint-plugin-no-secrets": "^1.1.2",
    "eslint-plugin-security": "^3.0.1",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
