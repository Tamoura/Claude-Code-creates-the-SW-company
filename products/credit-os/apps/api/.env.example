# Composable Credit OS — API environment (:5016)
# Copy to .env and adjust for your local setup.

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5016
HOST=0.0.0.0
LOG_LEVEL=info

# ── Database (PostgreSQL 15) ─────────────────────────────────────────────────
# Dev database used by `pnpm dev` and `prisma migrate dev`.
DATABASE_URL="postgresql://tamer@localhost:5432/credit_os_dev"
# Test database used by the Vitest integration project (real dependency, no mocks).
TEST_DATABASE_URL="postgresql://tamer@localhost:5432/credit_os_test"
# Prisma connection pool tuning (consumed by @connectsw/shared prisma plugin).
DATABASE_POOL_SIZE=20
DATABASE_POOL_TIMEOUT=10

# ── Auth — Keycloak OIDC (Phase 1, see docs/research.md) ─────────────────────
KEYCLOAK_ISSUER_URL="http://localhost:8080/realms/credit-os"
KEYCLOAK_CLIENT_ID="credit-os-api"
KEYCLOAK_CLIENT_SECRET="change-me"

# ── Tenancy (single-tenant, multi-tenant-ready — ADR-004) ────────────────────
DEFAULT_TENANT_ID="00000000-0000-0000-0000-000000000001"
