# =============================================================================
# RecomEngine - Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment.
# For docker-compose, these values are used as defaults with ${VAR:-default}.

# -- Database (PostgreSQL) --
POSTGRES_USER=recomengine
POSTGRES_PASSWORD=recomengine_dev
POSTGRES_DB=recomengine_dev
DATABASE_URL=postgresql://recomengine:recomengine_dev@localhost:5432/recomengine_dev

# -- Cache (Redis) --
REDIS_URL=redis://localhost:6379

# -- API Server --
PORT=5008
NODE_ENV=development
LOG_LEVEL=info

# -- Authentication --
# CHANGE THESE IN PRODUCTION - use a cryptographically random string (64+ chars)
JWT_SECRET=your-jwt-secret-change-in-production
API_KEY_HMAC_SECRET=your-hmac-secret-change-in-production

# -- Frontend --
NEXT_PUBLIC_API_URL=http://localhost:5008

# -- Optional: Error Tracking --
# SENTRY_DSN=

# -- Optional: Analytics --
# ANALYTICS_KEY=
